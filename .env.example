# Required server-side Gemini key. Do not expose this as NEXT_PUBLIC_*.
GEMINI_API_KEY=your_key_here

# Optional model overrides. When unset, the app uses stable-first fallback chains.
GEMINI_SCENARIO_MODEL=gemini-2.5-flash-lite
GEMINI_SIMULATION_MODEL=gemini-2.5-flash-lite
GEMINI_FEEDBACK_MODEL=gemini-2.5-flash
GEMINI_STT_MODEL=gemini-2.5-flash-lite
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_FALLBACK_MODELS=gemini-2.5-flash-preview-tts
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional transient overload retry tuning.
AI_MAX_RETRIES=3
AI_RETRY_BASE_MS=800
