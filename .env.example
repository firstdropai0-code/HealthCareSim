GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
AI_MAX_RETRIES=2
AI_RETRY_BASE_MS=800

# OpenAI powers voice only (speech-to-text + text-to-speech). Text generation
# stays on Gemini. Only OPENAI_API_KEY is required; the rest have defaults.
OPENAI_API_KEY=your_openai_key_here

# Must stay whisper-1. Word-level timestamps require response_format=verbose_json
# with timestamp_granularities, which only whisper-1 supports. Pointing this at a
# gpt-4o-* transcribe model still transcribes, but silently drops the timings, so
# pace/pause delivery metrics stop being captured.
OPENAI_TRANSCRIBE_MODEL=whisper-1

OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Fallback only. Each character's voice is pinned per scenario and passed
# explicitly on every call, so this is used only if none was supplied.
OPENAI_TTS_VOICE=alloy
